<clickhouse>
    <users>
        <default>
            <password replace="replace">PLACEHOLDER_DEFAULT_PASSWORD</password>
            <networks replace="replace">
                <ip>PLACEHOLDER_ALLOWED_NETWORKS</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>

        <readonly>
            <password>PLACEHOLDER_READONLY_PASSWORD</password>
            <networks>
                <ip>PLACEHOLDER_ALLOWED_NETWORKS</ip>
            </networks>
            <profile>readonly</profile>
            <quota>default</quota>
        </readonly>
    </users>

    <profiles>
        <default>
            <max_memory_usage>10000000000</max_memory_usage>
            <max_bytes_before_external_group_by>5000000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>5000000000</max_bytes_before_external_sort>
            <load_balancing>random</load_balancing>
            <async_insert>1</async_insert>
            <wait_for_async_insert>1</wait_for_async_insert>
            <async_insert_max_data_size>10000000</async_insert_max_data_size>
        </default>
        <readonly>
            <readonly>1</readonly>
            <max_memory_usage>5000000000</max_memory_usage>
            <max_bytes_before_external_group_by>2500000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>2500000000</max_bytes_before_external_sort>
            <load_balancing>random</load_balancing>
        </readonly>
    </profiles>
</clickhouse>
